<?xml version="1.0" encoding="utf-8"?>
<!--
  Publica um unico .exe self-contained (sem precisar de .NET instalado),
  comprimido e leve. Uso:
    dotnet publish src/SecretManager -c Release -p:PublishProfile=win-x64
  Saida em: src/SecretManager/bin/Release/net10.0-windows/win-x64/publish/SecretManager.exe
-->
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>Any CPU</Platform>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <PublishSingleFile>true</PublishSingleFile>
    <SelfContained>true</SelfContained>
    <PublishReadyToRun>true</PublishReadyToRun>
    <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <DebugType>none</DebugType>
  </PropertyGroup>
</Project>
