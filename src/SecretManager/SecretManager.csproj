<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <ApplicationManifest>app.manifest</ApplicationManifest>

    <!-- Identidade -->
    <AssemblyName>SecretManager</AssemblyName>
    <RootNamespace>SecretManager</RootNamespace>
    <Version>1.0.0</Version>
    <Product>Secret Manager</Product>
    <Company>Pablo</Company>

    <!-- Single-file leve, self-contained opcional via publish profile -->
    <SatelliteResourceLanguages>en;pt-BR</SatelliteResourceLanguages>
  </PropertyGroup>

  <ItemGroup>
    <!-- Argon2id puro-gerenciado para derivacao de chave resistente a GPU -->
    <PackageReference Include="Konscious.Security.Cryptography.Argon2" Version="1.3.1" />
  </ItemGroup>

</Project>
